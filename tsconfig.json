{
  "compilerOptions": {
    /* 基础设置 */
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    /* 严格模式 */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* 允许现代构建 */
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,

    /* 路径别名（新写法） */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* 忽略 TS6 deprecation 提示 */
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"]
}